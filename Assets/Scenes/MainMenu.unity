  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Welcome to the shop. Rules are simple: buy trash for pennies, sell it
    to fools for a fortune. But listen closely. Sometimes they bring... <color=#8A1C1C><i>other</i></color>
    things. You\u2019ll feel it when you hold one. It\u2019s cold. It breathes.\r\n\r\nThe
    golden rule: <color=#8A1C1C><b>Get rid of it before closing time.</b></color>
    Sell it to anyone, dump it for nothing, I don't care. Just don't leave it on
    the shelf after the shift ends. \r\n\r\nYou might wonder why you wake up with
    a headache? Why does it feel like you\u2019ve lived this day already, with the
    lingering taste of ash and blood in your mouth? Ignore it. Just <color=#555555><i>d\xE9j\xE0
    vu</i></color>. We\u2019ve all been working here... for a very long time. \r\n\r\nKeep
    an eye on the timer. If you fail, you\u2019ll be starting over. <color=#555555><i>Again.</i></color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: c92158e343f67ca43bc8ce757e4458f8, type: 2}
